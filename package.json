{
  "name": "durak-game",
  "version": "0.1.0",
  "private": true,
  "description": "Durak (Podkidnoy) mobile card game - monorepo root",
  "scripts": {
    "test": "pnpm --filter @durak/game-core test && pnpm --filter @durak/mobile test",
    "start": "pnpm --filter @durak/mobile start",
    "mobile": "pnpm --filter @durak/mobile start",
    "mobile:clear": "pnpm --filter @durak/mobile exec expo start -c",
    "web": "pnpm --filter @durak/web dev",
    "web:build": "pnpm --filter @durak/web build",
    "convex:deploy": "pnpm --filter @durak/mobile exec convex dev --once",
    "convex:fix-auth": "pnpm --filter @durak/mobile fix:auth",
    "convex:dev": "pnpm convex:deploy",
    "convex:once": "pnpm convex:deploy",
    "ios:preview": "pnpm --filter @durak/mobile exec eas build --platform ios --profile preview",
    "ios:preview:submit": "pnpm --filter @durak/mobile exec eas submit --platform ios --profile preview"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@11.4.0",
  "dependencies": {
    "expo": "~56.0.11",
    "react": "19.2.3",
    "react-native": "0.85.3"
  }
}
