{
  "expo": {
    "name": "Durak",
    "slug": "durak",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "durak",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kedrov.durakgame",
      "icon": {
        "light": "./assets/ios-icon-light.png",
        "dark": "./assets/ios-icon-dark.png",
        "tinted": "./assets/ios-icon-tinted.png"
      },
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CADisableMinimumFrameDurationOnPhone": true,
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.kedrov.durakgame",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f8c6d0c7-6ad7-42dd-a4ec-9a50bba3910c"
      }
    },
    "owner": "kedrov",
    "plugins": [
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/splash-icon.png",
          "color": "#0A0A0A"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#0A0A0A"
          }
        }
      ],
      [
        "@howincodes/expo-dynamic-app-icon",
        {
          "glass": {
            "ios": {
              "light": "./assets/ios-icon-glass-light.png",
              "dark": "./assets/ios-icon-glass-dark.png",
              "tinted": "./assets/ios-icon-glass-tinted.png"
            },
            "android": {
              "foregroundImage": "./assets/android-icon-foreground.png",
              "backgroundColor": "#0A0A0A"
            }
          },
          "tinted": {
            "ios": {
              "light": "./assets/ios-icon-tinted-light.png",
              "dark": "./assets/ios-icon-tinted-dark.png",
              "tinted": "./assets/ios-icon-tinted-tinted.png"
            },
            "android": {
              "foregroundImage": "./assets/android-icon-foreground.png",
              "backgroundColor": "#0A0A0A"
            }
          }
        }
      ]
    ]
  }
}
