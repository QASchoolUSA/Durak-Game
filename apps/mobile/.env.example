# Convex backend URL for online play (required for "With friends" mode)
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Preview deploy key — set in .env.local only, never commit.
# With this key, use `pnpm convex:dev` (deploy), not `convex dev`.
# Generate in Convex Dashboard → Project → Settings → Preview Deploy Key
# CONVEX_DEPLOY_KEY=
