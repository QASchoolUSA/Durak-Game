# Copy to .env.local — never commit .env.local
#
# Preview deploy key from dashboard (Settings → Preview → Deploy Key):
# CONVEX_DEPLOY_KEY=preview:team:project|<secret>
#
# Deploy backend, then paste the printed URL:
#   npx convex deploy --preview-name dev
# EXPO_PUBLIC_CONVEX_URL=https://your-preview.convex.cloud
# EXPO_PUBLIC_CONVEX_SITE_URL=https://your-preview.convex.site
#
# Or use interactive cloud dev (no deploy key):
#   npx convex login && npx convex dev --configure
